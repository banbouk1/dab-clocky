{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('DATABASE_CONNECTION_STRING')"
  },
  "runtime": {
    "host": {
      "authentication": {
        "provider": "AzureAD",
        "jwt": {
          "audience": "api://@env('ENTRA_DAB_CLIENT_ID')",
          "issuer": "https://sts.windows.net/@env('ENTRA_DAB_TENANT_ID')/"
        }
      }
    },
    "rest": {
      "enabled": true,
      "path": "/api"
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true      
    }
  },
  "entities": {
    "ViewSAP": {
      "source": "[dbo].[ViewSAP]",
      "permissions": [
        {
          "role": "dab.reader",
          "actions": [ { "action": "read" } ]
        }
      ]
    }
  }
}